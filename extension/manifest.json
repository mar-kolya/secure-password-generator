{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "description": "__MSG_extensionDescription__",
    "version": "1.0.11",
    "default_locale": "en",
    "homepage_url": "https://github.com/mar-kolya/secure-password-generator",
    "icons": {
	"16": "icons/password-16.png",
	"32": "icons/password-32.png",
	"48": "icons/password-48.png",
	"64": "icons/password-64.png"
    },

    "permissions": [
	"contextMenus",
	"activeTab",
	"scripting",
	"storage"
    ],

    "action": {
	"default_icon": {
	    "16": "icons/password-16.png",
	    "32": "icons/password-32.png",
	    "48": "icons/password-48.png",
	    "64": "icons/password-64.png"
	},
	"default_title": "Secure Password Generator",
	"default_popup": "popup.html"
    },

    "commands": {
	"generate-password": {
	    "suggested_key": {
		"default": "Alt+G"
	    },
	    "description": "Generate Password"
	},
	"insert-previous-password": {
	    "suggested_key": {
		"default": "Alt+L"
	    },
	    "description": "Insert Previous Password"
	}
    },

    "background": {
	"scripts": ["dist/background.js"],
	"service_worker": "dist/background.js"
    },

    "browser_specific_settings": {
	"gecko": {
	    "id": "password.generator@kolya.ca",
	    "data_collection_permissions": {
		"required": ["none"]
	    }
	}
    }
}
